# Datenbank – für lokale Entwicklung reicht SQLite, für Produktion Postgres
# Lokal (SQLite):   sqlite:///./chimaera.db
# Neon (Postgres):  postgresql://user:pass@ep-xxx.region.neon.tech/dbname?sslmode=require
DATABASE_URL=sqlite:///./chimaera.db

# Admin-Zugang – WICHTIG: für Produktion ändern!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-please

# Session-Signatur – irgendein langer Zufallsstring, z.B. `python -c "import secrets; print(secrets.token_urlsafe(48))"`
SECRET_KEY=change-this-to-a-long-random-string-in-production

# Festival-Name (wird in Formular + Mails eingesetzt)
FESTIVAL_NAME=Chimaera Festival

# Anforderungen für Helfer:in-Status (nur zur Anzeige im Formular)
MIN_SHIFTS=2
MIN_DAYS=2
BENEFITS_MIN_SHIFTS=3
BENEFITS_MIN_DAYS=3

# SMTP – optional. Wenn leer, wird Mail-Versand deaktiviert und nur Copy/CSV angeboten
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=helfer@chimaera-festival.de
SMTP_FROM_NAME=Chimaera Helfer-Team
SMTP_USE_TLS=true

# Dev-Flag: zeigt den Passwort-Reset-Link direkt auf der Seite an, wenn SMTP
# nicht konfiguriert ist. NUR in der lokalen Entwicklung auf true stellen!
DEBUG_SHOW_RESET_LINK=false
